---
interface Row {
  metal: string;
  scadrial: string;
  classic: string;
  desc: string;
}

const rows: Row[] = [
  { metal: 'Copper ↓', scadrial: 'store copper "..."', classic: 'save "..."', desc: 'Deposit an insight to the vault.' },
  { metal: 'Copper ↑', scadrial: 'tap copper "<q>"', classic: 'recall "<q>"', desc: 'Retrieve semantically (--deep / --expand).' },
  { metal: 'Bronze', scadrial: 'burn bronze "<q>"', classic: 'graph "<q>"', desc: 'Query the code graph (Seeker).' },
  { metal: 'Iron', scadrial: 'burn iron "<sym>"', classic: 'symbol "<sym>"', desc: 'Pull a symbol and its neighbors.' },
  { metal: 'Steel', scadrial: 'burn steel <o> <n>', classic: 'rename <o> <n>', desc: 'Coordinated rename via Serena.' },
  { metal: 'Tin', scadrial: 'burn tin', classic: 'verbose', desc: 'Enhanced output — verbose toggle.' },
  { metal: 'Pewter', scadrial: 'burn pewter', classic: 'reindex', desc: 'Force-rebuild the code graph.' },
  { metal: 'Zinc', scadrial: 'burn zinc "<bug>"', classic: 'debug "<bug>"', desc: 'Rioter — dispatch a team-debug session.' },
  { metal: 'Aluminum', scadrial: 'burn aluminum', classic: 'uninstall', desc: 'Reversible teardown (wipes install).' },
  { metal: 'Brass', scadrial: 'burn brass', classic: 'stamp', desc: 'Soother — re-imprint metalmind managed files (upgrade in place).' },
  { metal: 'Atium', scadrial: 'atium new | add', classic: 'daily new | add', desc: 'Future daily notes — --date today|tomorrow|next-workday|YYYY-MM-DD, --from carries unchecked items.' },
  { metal: 'Gold', scadrial: 'gold <note>', classic: 'scribe archive <note>', desc: 'Burn gold — archive a note (move to Archive/).' },
  { metal: 'Flare', scadrial: 'flare banner | dialog | sticky', classic: 'notify banner | dialog | sticky', desc: 'macOS desktop notifications — amplify a signal.' },
  { metal: 'Routine', scadrial: 'routine install eod', classic: 'routine install eod', desc: 'Schedule EOD carry-forward + archive — launchd agent 17:30 Mon–Fri (macOS).' },
  { metal: 'Forge', scadrial: 'forge create <g>', classic: 'group create <g>', desc: 'Define a cross-repo group.' },
  { metal: 'Forge', scadrial: 'forge add <g> <r>', classic: 'group add <g> <r>', desc: 'Add a repo to the group.' },
  { metal: 'Forge', scadrial: 'forge capture-spec <r> <url>', classic: 'group capture-spec <r> <url>', desc: 'Seed the OpenAPI shelf for cross-repo route edges.' },
  { metal: 'Forge', scadrial: 'burn bronze "<q>" --forge <g>', classic: 'graph "<q>" --group <g>', desc: 'Query across every repo in the group (--include-literals for URL-literal fallback).' },
  { metal: 'Scribe', scadrial: 'scribe <verb>', classic: 'note <verb>', desc: 'Vault CRUD — create · update · patch · delete · archive · rename · list · show.' },
  { metal: 'Release', scadrial: 'release-check', classic: 'release-check', desc: 'Preflight before tagging — working tree, branch, version sync, tests, build, stamped block.' },
  { metal: 'Seeker', scadrial: 'pulse', classic: 'doctor', desc: 'Pulse-check the install — prereqs, config, MCP state.' },
];
---

<div class="cmd-table-wrap">
  <table class="cmd-table">
    <thead>
      <tr>
        <th scope="col">Metal</th>
        <th scope="col">Command</th>
        <th scope="col">Description</th>
      </tr>
    </thead>
    <tbody>
      {rows.map((row) => (
        <tr>
          <td class="metal">{row.metal}</td>
          <td class="cmd">
            <span class="scadrial"><span style="opacity:0.5">$</span> metalmind {row.scadrial}</span>
            <span class="classic"><span style="opacity:0.5">$</span> metalmind {row.classic}</span>
          </td>
          <td class="desc">{row.desc}</td>
        </tr>
      ))}
    </tbody>
  </table>
</div>
