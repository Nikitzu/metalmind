#!/usr/bin/env bash
# metalmind SessionStart hook — injects a system-reminder so Claude knows the
# vault exists and which CLI verb to use for recall. Installed by
# `metalmind init` / refreshed by `metalmind burn brass` (aka `metalmind stamp`).
#
# Emits Claude Code's additionalContext JSON; silently no-ops if metalmind is
# missing from PATH so this never breaks a session.

RECALL_CMD="{{RECALL_CMD}}"

if ! command -v metalmind >/dev/null 2>&1; then
  exit 0
fi

cat <<EOF
{"hookSpecificOutput":{"hookEventName":"SessionStart","additionalContext":"metalmind memory is available. Before any non-trivial task (architecture, design, debugging, planning, saving), run 'Bash: ${RECALL_CMD} \"<query>\"' to recall prior decisions from the Obsidian vault at ~/Knowledge/. Add --deep for related notes, --expand for linked context. Recall is zero token cost — no MCP tools registered. Do NOT trust training-cutoff knowledge over the vault."}}
EOF
