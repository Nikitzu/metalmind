# Generated copy of packages/vault-rag (source of truth lives at packages/vault-rag/).
# Populated by cli/scripts/sync-vault-rag-pkg.mjs at build/prepack time so the
# npm tarball can bundle the Python package next to dist/cli.js.
cli/templates/vault-rag-pkg/

# Astro
.astro/

# recall-v0 bench — generator is source of truth; distractors and scratch
# results regenerate deterministically.
bench/recall-v0/fake-vault-distractors/
bench/recall-v0/results/*
!bench/recall-v0/results/.gitkeep
